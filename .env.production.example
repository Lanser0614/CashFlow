APP_NAME="Cash Flow 101"
APP_PORT=80
APP_URL=https://api.blatnoy.uz
APP_KEY=base64:replace_with_generated_key

DB_DATABASE=cashflow
DB_USERNAME=cashflow
DB_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

LIVEKIT_API_KEY=change_me_livekit_key
LIVEKIT_API_SECRET=change_me_livekit_secret
LIVEKIT_WS_URL=wss://blatnoy.uz/livekit

# Optional: override if NATS websocket is exposed somewhere else.
VITE_NATS_WS_URL=

# Optional: change only if host ports 7881/7882 are already occupied.
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT=7882
